generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  externalId String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cycles      CycleLog[]
  predictions PredictionResult[]
  moodLogs    MoodDailyLog[]
  moodPredictions MoodPredictionResult[]
  rppgSessions    RppgSession[]
  rppgPredictions RppgPredictionResult[]
}

model CycleLog {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  periodStartDate  DateTime
  periodEndDate    DateTime
  bleedingScores   Int[]
  hasOvulationPeak Boolean
  unusualBleeding  Boolean
  rppgOvulationDay Int?

  cycleLength      Int?
  mensesLength     Int
  totalMensesScore Int
  lutealLength     Int?
  fertilityDays    Int?
  ovulationDay     Int?

  cycleNumber Int
  loggedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PredictionResult {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  featCLV               Float
  featMeanCycleLen      Float
  featMeanLuteal        Float
  featLutealStd         Float
  featAnovulatoryRate  Float
  featMeanMensesLen    Float
  featMeanMensesScore  Float
  featUnusualBleedRate Float
  featMeanFertilityDays Float
  featNCycles          Int

  infertilityRiskProb  Float
  infertilityRiskScore Float
  infertilityRiskFlag  Int
  infertilitySeverity  String

  dysmenorrheaRiskProb  Float
  dysmenorrheaRiskScore Float
  dysmenorrheaRiskFlag  Int
  dysmenorrheaSeverity  String

  pmddRiskProb  Float
  pmddRiskScore Float
  pmddRiskFlag  Int
  pmddSeverity  String

  endometrialRiskProb  Float
  endometrialRiskScore Float
  endometrialRiskFlag  Int
  endometrialSeverity  String

  t2dRiskProb  Float
  t2dRiskScore Float
  t2dRiskFlag  Int
  t2dSeverity  String

  cvdRiskProb  Float
  cvdRiskScore Float
  cvdRiskFlag  Int
  cvdSeverity  String

  nCyclesUsed      Int
  predictionSource String

  criterion1Positive       Int @default(0)
  oligomenorrheaTriggered  Int @default(0)
  amenorrheaRiskTriggered  Int @default(0)
  irregularPatternTriggered Int @default(0)

  predictedAt DateTime @default(now())
}

model MoodDailyLog {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  logDate DateTime

  @@unique([userId, logDate])

  phq4Item1 Int?
  phq4Item2 Int?
  phq4Item3 Int?
  phq4Item4 Int?
  phq4AnxietyScore    Int?
  phq4DepressionScore Int?
  phq4Total           Int?
  phq4AnxietyFlag     Int?
  phq4DepressionFlag  Int?

  affectValence Int?
  affectArousal Int?
  affectQuadrant String?

  focusScore    Int?
  memoryScore   Int?
  mentalFatigue Int?
  cognitiveLoadScore Float?

  sleepQuality Float?
  hoursSlept   Float?
  sleepSatisfaction Float?

  psychBurdenScore Float?

  cyclePhase String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MoodPredictionResult {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  group       String
  predictedAt DateTime @default(now())
  nLogsUsed   Int

  anxietyRiskScore  Float?
  anxietyRiskProb   Float?
  anxietyRiskFlag   Int?
  anxietySeverity   String?

  depressionRiskScore  Float?
  depressionRiskProb   Float?
  depressionRiskFlag   Int?
  depressionSeverity   String?

  pmddRiskScore  Float?
  pmddRiskProb   Float?
  pmddRiskFlag   Int?
  pmddSeverity   String?

  stressRiskScore  Float?
  stressRiskProb   Float?
  stressRiskFlag   Int?
  stressSeverity   String?

  cvdRiskScore  Float?
  cvdRiskProb   Float?
  cvdRiskFlag   Int?
  cvdSeverity   String?

  t2dRiskScore  Float?
  t2dRiskProb   Float?
  t2dRiskFlag   Int?
  t2dSeverity   String?

  infertilityRiskScore  Float?
  infertilityRiskProb   Float?
  infertilityRiskFlag   Int?
  infertilitySeverity   String?

  strokeRiskScore  Float?
  strokeRiskProb   Float?
  strokeRiskFlag   Int?
  strokeSeverity   String?

  metsynRiskScore  Float?
  metsynRiskProb   Float?
  metsynRiskFlag   Int?
  metsynSeverity   String?
}

model RppgSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  rmssd     Float
  meanTemp  Float
  meanEda   Float
  asi       Float?

  sessionType    String   @default("checkin")
  sessionQuality String?
  capturedAt     DateTime @default(now())

  predictions RppgPredictionResult[] @relation("RppgSessionPredictions")
}

model RppgPredictionResult {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  group       String
  predictedAt DateTime @default(now())
  nSessionsUsed Int

  rmssdMean  Float
  rmssdMin   Float
  rmssdStd   Float
  tempMean   Float
  tempStd    Float
  edaMean    Float
  edaMax     Float
  edaStd     Float

  lowRmssdFlag    Int
  modLowRmssdFlag Int
  highEdaFlag     Int
  highAsiFlag     Int?

  stressRiskScore Float?
  stressRiskProb  Float?
  stressRiskFlag  Int?
  stressSeverity  String?

  cvdRiskScore    Float?
  cvdRiskProb     Float?
  cvdRiskFlag     Int?
  cvdSeverity     String?

  t2dRiskScore    Float?
  t2dRiskProb     Float?
  t2dRiskFlag     Int?
  t2dSeverity     String?

  metabolicRiskScore Float?
  metabolicRiskProb  Float?
  metabolicRiskFlag  Int?
  metabolicSeverity  String?

  heartFailureRiskScore Float?
  heartFailureRiskProb  Float?
  heartFailureRiskFlag  Int?
  heartFailureSeverity  String?

  infertilityRiskScore Float?
  infertilityRiskProb  Float?
  infertilityRiskFlag  Int?
  infertilitySeverity  String?

  anomalyFlag  Int?
  anomalyScore Float?

  sessions RppgSession[] @relation("RppgSessionPredictions")
}
